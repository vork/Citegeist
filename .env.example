# Copy this file to .env and fill in your API keys.
# .env is gitignored and will NOT be committed.

# Perplexity AI API key – required for the Perplexity search backend.
# Get yours at: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# Semantic Scholar API key – optional, enables higher rate limits (100 req/sec).
# Free keys at: https://www.semanticscholar.org/product/api#api-key
SEMANTIC_SCHOLAR_API_KEY=
